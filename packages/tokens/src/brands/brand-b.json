{
  "$schema": "https://design-tokens.org/schema.json",
  "description": "Brand B — Last Mile Delivery. Natural, trustworthy, fresh. Primary green palette + Plus Jakarta Sans.",

  "color": {
    "brand": {
      "primary":         { "$value": "#0A8920", "$type": "color", "$description": "Primary-500 — main CTA, filled buttons" },
      "primary-hover":   { "$value": "#07751B", "$type": "color", "$description": "Primary-600" },
      "primary-pressed": { "$value": "#046017", "$type": "color", "$description": "Primary-700" },
      "primary-subtle":  { "$value": "#E5F8E3", "$type": "color", "$description": "Primary-100" },
      "on-primary":      { "$value": "#ffffff", "$type": "color" },

      "secondary":        { "$value": "#2D3A41", "$type": "color", "$description": "Neutral-700 — especial buttons, nav" },
      "secondary-hover":  { "$value": "#232D34", "$type": "color", "$description": "Neutral-800" },
      "secondary-subtle": { "$value": "#E7EBEA", "$type": "color", "$description": "Neutral-200" },
      "on-secondary":     { "$value": "#ffffff", "$type": "color" },

      "accent":          { "$value": "#39AD3E", "$type": "color", "$description": "Primary-400 — highlights, badges" },
      "accent-subtle":   { "$value": "#E5F8E3", "$type": "color" },
      "on-accent":       { "$value": "#ffffff", "$type": "color" }
    },
    "surface": {
      "default":  { "$value": "#ffffff",  "$type": "color" },
      "sunken":   { "$value": "#F9FBFC",  "$type": "color" },
      "emphasis": { "$value": "#E5F8E3",  "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "#192126",  "$type": "color" },
      "secondary": { "$value": "#37474F",  "$type": "color" },
      "link":      { "$value": "#0A8920",  "$type": "color" }
    }
  },

  "font": {
    "family": {
      "sans": { "$value": "'Plus Jakarta Sans', system-ui, -apple-system, sans-serif", "$type": "fontFamily" }
    }
  },

  "component": {
    "button": {
      "border-radius": { "$value": "6px", "$type": "dimension", "$description": "Same as spec: border-radius 6px" },
      "padding-x":     { "$value": "16px", "$type": "dimension", "$description": "Spec: 16px horizontal padding" },
      "padding-y":     { "$value": "8px",  "$type": "dimension", "$description": "Spec: 8px vertical padding" }
    },
    "card": {
      "border-radius": { "$value": "10px", "$type": "dimension" }
    }
  },

  "brand-meta": {
    "name":       { "$value": "Brand B — Last Mile",   "$type": "other" },
    "logo-text":  { "$value": "FDS Delivery",          "$type": "other" },
    "nav-style":  { "$value": "topbar",                "$type": "other" }
  }
}
